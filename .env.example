# Optional overrides after deploy (Render Dashboard → each service → Environment).
# Most variables are wired automatically by render.yaml via fromDatabase / fromService.

# First admin password (set during Blueprint Apply if prompted)
INIT_PASSWORD=

# LLM providers — add in Dashboard or here; Dify also supports configuring models in the UI
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# External object storage (recommended for production instead of API disk only)
# STORAGE_TYPE=s3
# S3_BUCKET_NAME=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=
